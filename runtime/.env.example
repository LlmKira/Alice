# Alice Runtime secret-only env template
#
# 非敏感配置写在 runtime/config.toml。
# 这个文件只放 TOML 中 *_env 字段引用的 secret。
#
# 用法：
#   cp runtime/.env.example runtime/.env
#   nano runtime/.env

# Telegram MTProto
# 从 https://my.telegram.org/apps 获取。账号关联凭据，不应提交到仓库。
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Telegram 用户 ID。用于管理员权限和默认 operator channel 推导。
TELEGRAM_ADMIN=

# 默认 LLM endpoint key。
# 对应 runtime/config.toml 中 [[llm.endpoints]].api_key_env = "LLM_API_KEY"。
LLM_API_KEY=

# 可选 secret：只有在 config.toml 启用对应功能时才需要填写。
TTS_API_KEY=
TTS_GROUP_ID=
ASR_API_KEY=
EXA_API_KEY=
YOUTUBE_API_KEY=

# 可选：使用非默认 TOML 路径。
# ALICE_CONFIG_PATH=/path/to/config.toml

# 可选：运行时本地状态路径。数据库、缓存、prompt logs 等仍是实例级本地状态。
# ALICE_STATE_DIR=/path/to/alice-state

# 可选：诊断开关。
# ALICE_PROMPT_LOG=false
